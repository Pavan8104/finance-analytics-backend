# =============================================================================
# Finance Analytics API — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
PROJECT_NAME="Finance Analytics API"
API_V1_STR="/api/v1"
ENVIRONMENT="development"    # development | staging | production

# --- Security ---
# Generate a strong key:  openssl rand -hex 32
SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30          # 30 min for production
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Comma-separated list of allowed origins. Use specific domains in production.
# Example: CORS_ORIGINS="https://app.yourcompany.com,https://admin.yourcompany.com"
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# --- Database ---
# SQLite (Local / Development default if DATABASE_URL is unset):
#   Falls back to sqlite:///./finance.db automatically
# PostgreSQL (Staging / Production):
#   DATABASE_URL="postgresql://user:password@localhost:5432/finance_db"
DATABASE_URL=

# --- PostgreSQL (used by docker-compose) ---
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=finance_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
